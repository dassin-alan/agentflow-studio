# ============================================
# AgentFlow Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
#
# NOTE for v0.1.0: No API keys are required.
# The static demo runs entirely in the browser.
# API keys are only needed from v0.4.0 onward.
# ============================================

# --- OpenAI-compatible API (v0.4.0+) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic (Claude) API (v0.4.0+) ---
ANTHROPIC_API_KEY=

# --- DeepSeek API (v0.4.0+) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Gemini API (v0.4.0+) ---
GEMINI_API_KEY=

# --- Custom Agent Endpoint (v0.4.0+) ---
# Use this for self-hosted or local LLMs (Ollama, vLLM, etc.)
CUSTOM_AGENT_ENDPOINT=
CUSTOM_AGENT_API_KEY=

# --- Database (v0.2.0+) ---
# SQLite is the default for local development.
# PostgreSQL or MySQL for production (v1.0.0+).
DATABASE_URL=sqlite:///./agentflow.db

# --- Server (v0.4.0+) ---
HOST=127.0.0.1
PORT=8000

# --- Logging (v0.4.0+) ---
LOG_LEVEL=info

# --- Security (v0.4.0+) ---
# Secret key for JWT token signing.
SECRET_KEY=change-me-in-production
